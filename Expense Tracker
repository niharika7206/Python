expenses = []

while True:
    print("\n1.Add Expense")
    print("2.Show Total Expense")
    print("3.Show All Expenses")
    print("4.Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        amount = float(input("Enter amount: "))
        expenses.append(amount)

    elif choice == "2":
        print("Total Expense:", sum(expenses))

    elif choice == "3":
        for e in expenses:
            print(e)

    elif choice == "4":
        break
